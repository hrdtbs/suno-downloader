{
  "manifest_version": 3,
  "name": "Suno Downloader Token Helper",
  "version": "0.1.0",
  "description": "Send Suno session token to Suno Downloader",
  "permissions": ["alarms", "storage", "tabs"],
  "host_permissions": ["https://suno.com/*", "https://*.suno.com/*", "http://127.0.0.1:38946/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://suno.com/*", "https://*.suno.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://suno.com/*", "https://*.suno.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Suno Downloader"
  }
}

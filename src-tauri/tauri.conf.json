{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Suno Downloader",
  "version": "0.1.0",
  "identifier": "com.suno-downloader.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Suno Downloader",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../chrome-extension/**/*": "chrome-extension/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3MDNBNzlGNDg2MEZDODMKUldTRC9HQkluNmNENTUzQm53bVFnazhJaUpiRTBLT2xsaGVmeXpWZDk2VFczWkRlNVF6RnYyMWoK",
      "endpoints": [
        "https://github.com/hrdtbs/suno-downloader/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
